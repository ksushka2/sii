import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans
from sklearn.preprocessing import RobustScaler
from sklearn.metrics import silhouette_score, adjusted_rand_score

train = pd.read_csv("disease_train.csv")

X = train.drop("Y", axis=1)

scaler = RobustScaler()
X_scaled = scaler.fit_transform(X)

wcssValues = []
kValues = list(range(1, 11))

for k in kValues:
    model = KMeans(n_clusters=k, random_state=42, n_init=10)
    model.fit(X_scaled)
    wcssValues.append(model.inertia_)

optimalK = None
maxChange = -float('inf')

for i in range(1, len(wcssValues) - 1):
    prev = wcssValues[i - 1] - wcssValues[i]
    next = wcssValues[i] - wcssValues[i + 1]

    change = prev - next

    if change > maxChange:
        maxChange = change
        optimalK = kValues[i]

print("Оптимальное k:", optimalK)

kmeans_final = KMeans(n_clusters=optimalK, random_state=42, n_init=10)
clusters = kmeans_final.fit_predict(X_scaled)

train["Cluster"] = clusters

print("\nРаспределение по кластерам:")
print(train["Cluster"].value_counts())

print("\nТаблица соответствия кластеров и истинных классов Y:")
print(pd.crosstab(train["Y"], train["Cluster"]))

print("")
labels = kmeans_final.labels_
print("Оценка качества через коэффициент силуета:",silhouette_score(X_scaled, labels))
